rules_version = '2';

// Rutas usadas en el cliente: settingsService (branding), transactionService, paymentService
service firebase.storage {
  match /b/{bucket}/o {
    match /branding/logo {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /branding/{tenantId}/logo {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /transactions/{transactionId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /payment-attachments/{transactionId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
