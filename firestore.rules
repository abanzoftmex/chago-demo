rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===== HELPER FUNCTIONS =====
    
    // Verificar si el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Obtener el UID del usuario autenticado
    function getCurrentUser() {
      return request.auth.uid;
    }
    
    // Verificar si el usuario tiene un tenant asignado
    function hasUserTenant() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(getCurrentUser())) &&
        get(/databases/$(database)/documents/users/$(getCurrentUser())).data.tenantId != null;
    }
    
    // Obtener el tenant ID del usuario
    function getUserTenantId() {
      return get(/databases/$(database)/documents/users/$(getCurrentUser())).data.tenantId;
    }
    
    // Verificar si el usuario es miembro activo de un tenant
    function isActiveTenantMember(tenantId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(getCurrentUser())) &&
        get(/databases/$(database)/documents/tenants/$(tenantId)/members/$(getCurrentUser())).data.status == 'active';
    }
    
    // Obtener el rol del usuario en un tenant
    function getUserTenantRole(tenantId) {
      return get(/databases/$(database)/documents/tenants/$(tenantId)/members/$(getCurrentUser())).data.role;
    }
    
    // Verificar si el usuario es admin de un tenant
    function isAdminOfTenant(tenantId) {
      return isActiveTenantMember(tenantId) && 
        getUserTenantRole(tenantId) == 'admin';
    }
    
    // Verificar si el usuario es admin o contador de un tenant
    function canManageDataInTenant(tenantId) {
      return isActiveTenantMember(tenantId) && 
        getUserTenantRole(tenantId) in ['admin', 'contador'];
    }
    
    // Verificar si el usuario puede leer datos de un tenant
    function canReadTenantData(tenantId) {
      return isActiveTenantMember(tenantId) && 
        getUserTenantRole(tenantId) in ['admin', 'contador', 'viewer'];
    }
    
    // Verificar si el usuario puede eliminar datos de un tenant
    function canDeleteTenantData(tenantId) {
      return isActiveTenantMember(tenantId) && 
        getUserTenantRole(tenantId) == 'admin';
    }
    
    // Verificar si el usuario es el propietario de un tenant
    function isTenantOwner(tenantId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/tenants/$(tenantId)) &&
        get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerUid == getCurrentUser();
    }
    
    // ===== REGLAS PARA USUARIOS =====
    
    // Colección de usuarios - Cada usuario puede leer y actualizar su propio documento
    match /users/{userId} {
      allow read: if isAuthenticated() && getCurrentUser() == userId;
      allow create: if isAuthenticated() && getCurrentUser() == userId;
      allow update: if isAuthenticated() && getCurrentUser() == userId &&
        // Prevenir que el usuario modifique su propio tenantId
        (!('tenantId' in request.resource.data) || 
         (request.resource.data.tenantId == resource.data.tenantId));
      allow delete: if false; // Los usuarios no pueden eliminarse a sí mismos
    }
    
    // ===== REGLAS PARA TENANTS =====
    
    // Colección de tenants - Solo los miembros pueden leer la info del tenant
    match /tenants/{tenantId} {
      allow read: if isActiveTenantMember(tenantId);
      allow create: if isAuthenticated(); // Permitir crear tenant durante registro
      allow update: if isAdminOfTenant(tenantId);
      allow delete: if isTenantOwner(tenantId); // Solo el dueño puede eliminar el tenant
      
      // ===== SUBCOLECCIÓN: MEMBERS =====
      
      // Miembros del tenant - Solo admins pueden gestionar miembros
      match /members/{memberId} {
        allow read: if isActiveTenantMember(tenantId);
        allow create: if isAdminOfTenant(tenantId);
        allow update: if isAdminOfTenant(tenantId) &&
          // Prevenir que un admin se desactive a sí mismo si es el owner
          !(getCurrentUser() == memberId && 
            isTenantOwner(tenantId) && 
            request.resource.data.status != 'active');
        allow delete: if isAdminOfTenant(tenantId) &&
          // Prevenir que el owner se elimine a sí mismo
          !(getCurrentUser() == memberId && isTenantOwner(tenantId));
      }
      
      // ===== SUBCOLECCIÓN: ENTRADAS =====
      
      // Entradas del tenant
      match /entradas/{entradaId} {
        allow read: if canReadTenantData(tenantId);
        allow create: if canManageDataInTenant(tenantId) &&
          // Asegurar que se incluyan metadatos de auditoría
          request.resource.data.createdBy == getCurrentUser() &&
          request.resource.data.createdAt == request.time;
        allow update: if canManageDataInTenant(tenantId) &&
          // Asegurar que se actualicen metadatos de auditoría
          request.resource.data.updatedBy == getCurrentUser() &&
          request.resource.data.updatedAt == request.time;
        allow delete: if canDeleteTenantData(tenantId);
      }
      
      // ===== SUBCOLECCIÓN: SALIDAS =====
      
      // Salidas del tenant
      match /salidas/{salidaId} {
        allow read: if canReadTenantData(tenantId);
        allow create: if canManageDataInTenant(tenantId) &&
          request.resource.data.createdBy == getCurrentUser() &&
          request.resource.data.createdAt == request.time;
        allow update: if canManageDataInTenant(tenantId) &&
          request.resource.data.updatedBy == getCurrentUser() &&
          request.resource.data.updatedAt == request.time;
        allow delete: if canDeleteTenantData(tenantId);
      }
      
      // ===== SUBCOLECCIÓN: TRANSACCIONES =====
      
      // Transacciones del tenant
      match /transacciones/{transaccionId} {
        allow read: if canReadTenantData(tenantId);
        allow create: if canManageDataInTenant(tenantId) &&
          request.resource.data.createdBy == getCurrentUser() &&
          request.resource.data.createdAt == request.time;
        allow update: if canManageDataInTenant(tenantId) &&
          request.resource.data.updatedBy == getCurrentUser() &&
          request.resource.data.updatedAt == request.time;
        allow delete: if canDeleteTenantData(tenantId);
      }
      
      // ===== SUBCOLECCIONES: CATÁLOGOS =====
      
      // Conceptos del tenant
      match /conceptos/{conceptoId} {
        allow read: if canReadTenantData(tenantId);
        allow create: if canManageDataInTenant(tenantId);
        allow update: if canManageDataInTenant(tenantId);
        allow delete: if canDeleteTenantData(tenantId);
      }
      
      // Subconceptos del tenant
      match /subconceptos/{subconceptoId} {
        allow read: if canReadTenantData(tenantId);
        allow create: if canManageDataInTenant(tenantId);
        allow update: if canManageDataInTenant(tenantId);
        allow delete: if canDeleteTenantData(tenantId);
      }
      
      // Proveedores del tenant
      match /proveedores/{proveedorId} {
        allow read: if canReadTenantData(tenantId);
        allow create: if canManageDataInTenant(tenantId);
        allow update: if canManageDataInTenant(tenantId);
        allow delete: if canDeleteTenantData(tenantId);
      }
      
      // Descripciones del tenant
      match /descripciones/{descripcionId} {
        allow read: if canReadTenantData(tenantId);
        allow create: if canManageDataInTenant(tenantId);
        allow update: if canManageDataInTenant(tenantId);
        allow delete: if canDeleteTenantData(tenantId);
      }
      
      // Generales del tenant
      match /generales/{generalId} {
        allow read: if canReadTenantData(tenantId);
        allow create: if canManageDataInTenant(tenantId);
        allow update: if canManageDataInTenant(tenantId);
        allow delete: if canDeleteTenantData(tenantId);
      }
      
      // ===== SUBCOLECCIÓN: CONFIGURACIONES =====
      
      // Configuraciones del tenant - Solo admins
      match /configuraciones/{configId} {
        allow read: if isActiveTenantMember(tenantId);
        allow write: if isAdminOfTenant(tenantId);
      }

      // Settings (branding, etc.) — usado por settingsService (logo en settings/branding)
      match /settings/{settingId} {
        allow read: if isActiveTenantMember(tenantId);
        allow write: if isAdminOfTenant(tenantId);
      }
      
      // ===== SUBCOLECCIÓN: LOGS AUDITORÍA =====
      
      // Logs de auditoría del tenant - Solo lectura para admins
      match /audit_logs/{logId} {
        allow read: if isAdminOfTenant(tenantId);
        allow create: if isActiveTenantMember(tenantId); // Sistema puede crear logs
        allow update, delete: if false; // Los logs no se pueden modificar
      }
    }
    
    // ===== REGLAS LEGACY (COMPATIBILIDAD) =====
    
    // Roles legacy - Solo lectura para usuarios autenticados
    match /roles/{roleId} {
      allow read: if isAuthenticated();
      allow write: if false; // Solo admins a través del backend
    }
    
    // Reglas para datos legacy (sistema anterior)
    // Solo aplicar si el usuario NO tiene tenant asignado
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && !hasUserTenant();
      allow create: if isAuthenticated() && !hasUserTenant();
      allow update: if isAuthenticated() && !hasUserTenant();
      allow delete: if isAuthenticated() && !hasUserTenant();
    }
    
    // Catálogos legacy
    match /{catalog}/{docId} {
      allow read: if isAuthenticated() && !hasUserTenant() && 
        catalog in ['concepts', 'subconcepts', 'descriptions', 'providers', 'generals'];
      allow write: if isAuthenticated() && !hasUserTenant() && 
        catalog in ['concepts', 'subconcepts', 'descriptions', 'providers', 'generals'];
    }
    
    // Gastos recurrentes legacy
    match /recurring_expenses/{expenseId} {
      allow read: if isAuthenticated() && !hasUserTenant();
      allow write: if isAuthenticated() && !hasUserTenant();
    }
    
    // ===== REGLAS ADICIONALES DE SEGURIDAD =====
    
    // Prevenir acceso a cualquier otra colección no definida
    match /{document=**} {
      allow read, write: if false;
    }
  }
}